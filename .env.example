# Where the landing CTAs send visitors (the tenant dashboard origin).
NEXT_PUBLIC_APP_URL=https://www.appido.io/dashboard

# Backend origin — the server-side /api/track route forwards landing events to ${APPIDO_API_BASE}/api/track.
APPIDO_API_BASE=https://api.appido.io

# Optional: override the event sink with any webhook (n8n / CRM). Takes precedence over APPIDO_API_BASE.
# CRM_WEBHOOK_URL=
